# App
DEBUG=true

# Database
DATABASE_URL=postgresql://rawy:rawy@localhost:5432/rawy

# JWT (üretimde güçlü rastgele anahtar kullanın)
SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Ajanda (odak 2–4 saat, bloklar arası boşluk)
FOCUS_BLOCK_MIN_HOURS=2
FOCUS_BLOCK_MAX_HOURS=4
CALENDAR_BUFFER_MINUTES=15

# Smart AI (Transformers)
AI_SUMMARY_MODEL=facebook/bart-large-cnn
AI_ZERO_SHOT_MODEL=facebook/bart-large-mnli
AI_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Weekly email report (optional)
WEEKLY_EMAIL_REPORT_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
